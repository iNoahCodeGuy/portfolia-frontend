# Backend API (FastAPI on Railway). The chat UI posts to `${NEXT_PUBLIC_API_URL}/chat`.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Password for /dashboard. If unset, the dashboard fails closed (503).
DASHBOARD_PASSWORD=choose-a-strong-password

# Supabase — used server-side only, by the /api/analytics routes.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
